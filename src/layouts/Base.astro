---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'marginalia', description = 'uno stream personale' } = Astro.props;
const base = import.meta.env.BASE_URL; // '/astro/'
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Apply theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        var stored = sessionStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <link rel="alternate" type="application/atom+xml" href={base + 'feed.xml'} title="marginalia" />
  </head>
  <body>
    <header>
      <div class="header-left">
        <a href={base} class="site-name">marginalia</a>
        <nav>
          <a href={base + 'archivio'}>archivio</a>
          <a href={base + 'now'}>ora</a>
        </nav>
      </div>
      <div class="header-right">
        <a href={base + 'feed.xml'} class="icon-link" aria-label="feed Atom" title="feed Atom">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
        <button id="theme-toggle" aria-label="cambia tema" title="cambia tema">
          <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </div>
    </header>

    <slot />

    <script>
      const toggle = document.getElementById('theme-toggle')!;
      const html = document.documentElement;

      function updateIcons() {
        const isDark = html.getAttribute('data-theme') === 'dark';
        toggle.querySelector<SVGElement>('.icon-moon')!.style.display = isDark ? 'none' : 'block';
        toggle.querySelector<SVGElement>('.icon-sun')!.style.display = isDark ? 'block' : 'none';
      }

      updateIcons();

      toggle.addEventListener('click', () => {
        const isDark = html.getAttribute('data-theme') === 'dark';
        html.setAttribute('data-theme', isDark ? 'light' : 'dark');
        sessionStorage.setItem('theme', isDark ? 'light' : 'dark');
        updateIcons();
      });
    </script>
  </body>
</html>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.03em;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a {
    font-size: 0.82rem;
    color: var(--muted);
    transition: color 0.1s;
  }

  nav a:hover {
    color: var(--text);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .icon-link {
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color 0.1s;
  }

  .icon-link:hover {
    color: var(--text);
  }

  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    padding: 0;
    display: flex;
    align-items: center;
    transition: color 0.1s;
  }

  #theme-toggle:hover {
    color: var(--text);
  }
</style>
