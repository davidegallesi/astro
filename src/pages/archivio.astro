---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const thoughts = await getCollection('thoughts');
thoughts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}

function formatTime(date: Date) {
  return date.toLocaleTimeString('it-IT', {
    hour: '2-digit',
    minute: '2-digit',
  });
}

const rendered = await Promise.all(
  thoughts.map(async (thought) => {
    const { Content } = await render(thought);
    return { thought, Content };
  })
);

const years = [...new Set(thoughts.map((t) => t.data.date.getFullYear()))].sort((a, b) => b - a);
---

<Base title="archivio — pensieri">
  <header>
    <h1><a href={import.meta.env.BASE_URL}>pensieri</a></h1>
    <p class="subtitle">archivio</p>
  </header>

  <div class="filter">
    <label for="year-select">anno</label>
    <select id="year-select">
      <option value="tutti">tutti</option>
      {years.map((y) => <option value={String(y)}>{y}</option>)}
    </select>
  </div>

  <main>
    {rendered.map(({ thought, Content }) => (
      <article data-year={thought.data.date.getFullYear()}>
        <time datetime={thought.data.date.toISOString()}>
          <span class="date">{formatDate(thought.data.date)}</span>
          <span class="time">{formatTime(thought.data.date)}</span>
        </time>
        <div class="body">
          <Content />
        </div>
      </article>
    ))}
  </main>
</Base>

<script>
  const select = document.getElementById('year-select') as HTMLSelectElement;
  const articles = document.querySelectorAll<HTMLElement>('article[data-year]');

  select.addEventListener('change', () => {
    const selected = select.value;
    articles.forEach((article) => {
      article.hidden = selected !== 'tutti' && article.dataset.year !== selected;
    });
  });
</script>

<style>
  header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
  }

  h1 {
    font-size: 1rem;
    font-weight: normal;
    letter-spacing: 0.05em;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  h1 a {
    color: inherit;
  }

  h1 a:hover {
    color: var(--text);
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.6;
    margin-top: 0.25rem;
  }

  .filter {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .filter label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .filter select {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.25rem 0.5rem;
    cursor: pointer;
  }

  article {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  article:last-of-type {
    border-bottom: none;
  }

  time {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .date {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--muted);
  }

  .time {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted);
    opacity: 0.6;
  }

  .body {
    font-size: 1rem;
    line-height: 1.7;
  }

  .body :global(p) {
    margin-bottom: 0.75em;
  }

  .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .body :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
